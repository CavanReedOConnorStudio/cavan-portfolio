---
import ArtworkLayout from "../../layouts/ArtworkLayout.astro";
import { works } from "../../data/works.js";
---

<ArtworkLayout title="Works" current="works">

  <div class="works-grid">

    {works.map((work) => (
      <a
        href={`/works/${work.slug}`}
        class="work-item"
      >

        <div class="image-frame">
          <img
            src={work.thumb}
            data-full={work.image}
            alt={work.title}
            loading="lazy"
            decoding="async"
          />
        </div>

        <div class="overlay">
          <span>{work.title}</span>
        </div>

      </a>
    ))}

  </div>

  <!-- progressive enhancement (optional preload full images on hover) -->
 <script is:inline>
  const imgs = document.querySelectorAll(".image-frame img");

  imgs.forEach((img) => {
    const full = img.getAttribute("data-full");

    if (!full) return;

    const preload = new Image();
    preload.src = full;

    preload.onload = () => {
      img.src = full;
      img.classList.add("loaded");
    };
  });
</script>

</ArtworkLayout>