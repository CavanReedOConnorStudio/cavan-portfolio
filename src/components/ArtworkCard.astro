---
/* =========================
   PROPS
========================= */
const { title, image, description } = Astro.props;
---

<!-- =========================
     ARTWORK CARD
========================= -->
<article class="artwork-card">

  <img src={image} alt={title} />

  <h2>{title}</h2>

  {description && (
    <p class="description">{description}</p>
  )}

</article>
